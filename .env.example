# ── Server ────────────────────────────────────────────────────
PORT=3001
ADMIN_SECRET=change-this-to-a-long-random-string

# ── Firebase Admin SDK ────────────────────────────────────────
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=goos-vx-7302a
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@goos-vx-7302a.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Africa's Talking (SMS) ────────────────────────────────────
# Sign up at: africastalking.com → Settings → API Keys
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_africastalking_username
AT_SENDER_ID=GOOS          # Your registered shortcode/alphanumeric (optional)

# ── Email (Gmail SMTP) ────────────────────────────────────────
# Use a Gmail account with App Passwords enabled
# Gmail → Account → Security → 2FA → App Passwords → Generate
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM_NAME=GO OS SaaS
EMAIL_FROM_ADDR=your-email@gmail.com

# ── Flutterwave Webhook ───────────────────────────────────────
FLW_SECRET_HASH=your-flutterwave-webhook-secret-hash
